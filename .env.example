# LLM
ANTHROPIC_API_KEY=your_anthropic_key_here
LLM_MODEL=claude-sonnet-4-6

# Flights (Amadeus - free test tier available)
AMADEUS_API_KEY=your_amadeus_key_here
AMADEUS_API_SECRET=your_amadeus_secret_here

# Places / Attractions
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Weather
OPENWEATHER_API_KEY=your_openweather_key_here

# Hotels (optional — mock data used if absent)
BOOKING_API_KEY=your_booking_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/travelmate
CHROMA_PERSIST_DIR=./chroma_store

ENV=development
